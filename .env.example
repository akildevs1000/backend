# FILE: backend/.env.example
# Copy to .env and fill in your values

# ─── Application ──────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_PASSWORD@postgres:5432/facial_attendance

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_REDIS_PASSWORD@redis:6379/0

# ─── Security ─────────────────────────────────────────────────────────────────
# IMPORTANT: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_64_CHARACTER_STRING_MINIMUM

# ─── AI Model ─────────────────────────────────────────────────────────────────
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_CTX_ID=0          # 0=GPU, -1=CPU
FACE_MATCH_THRESHOLD=0.6      # Cosine similarity threshold (0.5–0.75)
FACE_DETECTION_THRESHOLD=0.5
LIVENESS_ENABLED=true
LIVENESS_THRESHOLD=0.7

# ─── FAISS Index ──────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=/app/data/faiss/index.bin
FAISS_INDEX_TYPE=IVFFlat      # IVFFlat (large) or Flat (small datasets)
FAISS_NLIST=100
FAISS_NPROBE=10

# ─── Storage ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/data/uploads
PROFILE_PHOTOS_DIR=/app/data/photos

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","https://your-frontend.com"]
